# Supabase (public — used by Next.js client)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Local scripts only — never expose to the browser
SUPABASE_SERVICE_ROLE_KEY=

# Custom Edge Function secret (add in Dashboard → Edge Functions → Secrets)
# Do NOT prefix with SUPABASE_ — those are auto-injected by Supabase
CRON_SECRET=
